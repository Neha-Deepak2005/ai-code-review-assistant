# Copy this file to `.env` and fill in real values.
# NEVER commit the real .env — add it to .gitignore.

SECRET_KEY=replace-with-a-long-random-string
JWT_SECRET_KEY=replace-with-a-different-long-random-string

# Leave DATABASE_URL unset to use local SQLite (app.db).
# For Supabase: Project Settings -> Database -> Connection string (URI)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

# You'll need this from Day 8 onward:
# OPENAI_API_KEY=sk-...
